{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "BloomDate: servidor local",
      "type": "shell",
      "command": "npm.cmd",
      "args": ["run", "dev", "--", "--host", "0.0.0.0"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen",
        "instanceLimit": 1
      },
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE.*ready|Local:",
          "endsPattern": "Local:.*http://"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "clear": false
      }
    }
  ]
}
